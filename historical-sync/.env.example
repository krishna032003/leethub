LEETCODE_SESSION=your_leetcode_session_cookie
CSRF_TOKEN=your_csrf_token_cookie
SYNC_MODE=full_history # Set to 'latest_only' to only keep the newest accepted submission
DELAY=1.0 # Delay in seconds between requests to avoid rate limits
RETRIES=5 # Number of retries for API calls
AUTO_PUSH=false # Set to true to run 'git push origin main' automatically
REPO_PATH=. # Path to your existing Git repository where you want to sync the files
