{
  "manifest_version": 3,
  "name": "LeetHub Sync",
  "version": "2.0",
  "key": "",
  "description": "Automatically sync your LeetCode accepted submissions to GitHub via OAuth.",
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*",
    "https://github.com/login/oauth/access_token"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*", "https://leetcode.com/submissions/*"],
      "js": ["content.js"]
    }
  ]
}
