{
  "manifest_version": 3,
  "name": "LeetCode Auto-Sync",
  "version": "1.0",
  "description": "Automatically sync your LeetCode accepted submissions to GitHub.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"]
    }
  ]
}
